import 'package:sqflite/sqflite.dart';
import 'package:path/path.dart';

class DbHelperconquistas {

  initDB() async {
    String path = await getDatabasesPath();
    String dbName = 'conquistas.db';
    String dbPath = join(path, dbName);

    Database db = await openDatabase(dbPath, version: 1, onCreate: onCreateDB);
    return db;
  }

  onCreateDB(Database db, int version) async {
    String sql = '''
      CREATE TABLE CONQUISTAS(
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        titulo TEXT NOT NULL,
        descricao TEXT NOT NULL,
        desbloqueado INTEGER NOT NULL DEFAULT 0
      );
    ''';
    await db.execute(sql);

    await db.insert('CONQUISTAS', {
      'titulo': 'Primeiro Passo',
      'descricao': 'Iniciou a jornada no app',
      'desbloqueado': 0
    });

    await db.insert('CONQUISTAS', {
      'titulo': 'Explorador de Humanas',
      'descricao': 'Acertou 5 questões de história',
      'desbloqueado': 0
    });
  }


  Future<List<Map<String, dynamic>>> buscarConquistas() async {
    Database db = await initDB();
    return await db.query('CONQUISTAS');
  }

  Future<int> atualizarConquistas(int id) async {
    Database db = await initDB();
    return await db.update(
      'CONQUISTAS',
      {'desbloqueado': 1},
      where: 'id = ?',
      whereArgs: [id],
    );
  }
}
